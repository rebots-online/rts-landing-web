# RevenueCat Web Billing public API key. Public client key only; never put a secret API key here.
VITE_REVENUECAT_API_KEY=

# Entitlement unlocked by the selected package.
VITE_REVENUECAT_ENTITLEMENT=readthissheet_pro

# Optional offering/package IDs. If omitted, the current offering and the first matching package are used.
VITE_REVENUECAT_OFFERING_ID=
VITE_REVENUECAT_PACKAGE_ID=

# Optional authenticated App User ID supplied by your shared auth layer.
# Leave unset to use a browser-persisted anonymous RevenueCat ID + Redemption Links.
VITE_REVENUECAT_APP_USER_ID=

# URL returned after entitlement verification. Do not point this at an unprotected premium file.
VITE_ENTITLED_DOWNLOAD_URL=

# Canonical public origin, without trailing slash.
VITE_SITE_URL=https://readthissheet.robin.mba

# Public Hugging Face Space origin used by the optional embedded AI music lab.
# Replace with the dedicated RobinsAIWorld Space after it is created.
VITE_HF_SPACE_URL=https://ace-step-ace-step-v1-5.hf.space

# Hugging Face Space publishing. HF_TOKEN is a write-scoped secret used only
# by deploy-hf-space.sh; its value belongs in Admin-Manual, never here.
HF_TOKEN=
HF_SOURCE_SPACE=ACE-Step/Ace-Step-v1.5
HF_SPACE_ID=RobinsAIWorld/rts-music-lab
HF_SPACE_HARDWARE=zero-a10g

# Deployment credentials belong only in:
# ~/Admin-Manual/CREDENTIALS/RTS-LANDING-WEB/dot-env
# These empty names document the public interface; never commit real values.
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
